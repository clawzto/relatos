# ── Relatos IA — Variables de entorno ──────────────────────────
# Copia este fichero como .env y rellena tus valores reales.
# NUNCA subas .env a Git (ya está en .gitignore).

# Flask
SECRET_KEY=cambia-esto-por-algo-aleatorio-y-largo

# ── OpenRouter ─────────────────────────────────────────────────
# Obtén tu clave en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Ollama (local) ─────────────────────────────────────────────
# URL por defecto cuando corres `ollama serve`
OLLAMA_URL=http://localhost:11434

# ── Open WebUI ─────────────────────────────────────────────────
OPENWEBUI_URL=http://localhost:3000
# Solo necesaria si tienes autenticación activada en Open WebUI
OPENWEBUI_API_KEY=
